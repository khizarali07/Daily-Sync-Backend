# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/dailysync?schema=public

# JWT Secret
JWT_SECRET=change-this-in-production

# Server
PORT=5000
NODE_ENV=development

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Email Configuration (SMTP)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=your-smtp-user
EMAIL_PASSWORD=your-smtp-password
EMAIL_FROM=your-email@example.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# OpenAI-compatible local AI server (LM Studio)
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=lm-studio

# AI provider switch: gemini | lmstudio
AI_PROVIDER=gemini

# Gemini settings (used when AI_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-flash-latest

# LM Studio settings (used when AI_PROVIDER=lmstudio)
LMSTUDIO_BASE_URL=http://127.0.0.1:1500/v1
LMSTUDIO_MODEL=qwen3.5-9b-uncensored-hauhaucs-aggressive
LMSTUDIO_API_KEY=your-lmstudio-key
